generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("student") // student, teacher, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
}

model Resource {
  id          String   @id @default(uuid())
  title       String
  description String?
  filePath    String
  subject     String
  uploaderId  String
  status      ResourceStatus @default(PENDING)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

